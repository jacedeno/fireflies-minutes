# Fireflies API Configuration
# Get your API key from: https://app.fireflies.ai/settings/api
FIREFLIES_API_KEY=your_fireflies_api_key_here

# Resend Email API Configuration
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=reports@your-domain.com

# GitHub Configuration
# Create a personal access token at: https://github.com/settings/tokens
# Scopes needed: repo (full control of private repositories)
GITHUB_TOKEN=ghp_your_github_token_here

# GitHub Repository Details
GITHUB_OWNER=your-github-username
GITHUB_REPO=fireflies-minutas

# Email Recipients
# Primary recipient for meeting minutes
MEETING_RECIPIENT_EMAIL=jose@your-domain.com

# Optional: JSON mapping of attendee names to email addresses
# Format: {"John Doe": "john@domain.com", "Jane Smith": "jane@domain.com"}
MEETING_ATTENDEES_JSON={}

# Routine Execution Configuration
# Schedule: in cron format or use Fireflies webhook trigger
# Examples:
#   "0 14 * * *"     = Daily at 2 PM (UTC)
#   "0 9 * * 1-5"    = Weekdays at 9 AM (UTC)
ROUTINE_SCHEDULE=0 14 * * *

# Optional: Timezone for schedule (IANA format)
# Examples: America/Denver, America/New_York, Europe/London
ROUTINE_TIMEZONE=America/Denver
