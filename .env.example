# Fireflies meeting minutes routine — environment variables.
#
# This file is for local smoke testing only. In production these values live as:
#   - Worker secrets (set via `wrangler secret put`)
#   - Claude Code Routine secrets (set in the routine config)

# === Fireflies ===
# https://app.fireflies.ai/settings/api
FIREFLIES_API_KEY=

# Shared secret used to sign Fireflies webhook deliveries (HMAC).
# Set the same value in the Fireflies dashboard and in the Worker.
FIREFLIES_WEBHOOK_SECRET=

# === Cloudflare Worker ===
# Public base URL for the Worker (custom domain recommended).
WORKER_BASE_URL=https://webhook.geekendzone.com

# Random 32-char token. Used by the routine to call the Worker queue API.
# Set the same value as a Worker secret and as a routine secret.
WORKER_ADMIN_TOKEN=

# === Resend ===
# https://resend.com/api-keys
RESEND_API_KEY=

# Must be on a domain verified in Resend.
RESEND_FROM_EMAIL=minutes@geekendzone.com

# === GitHub ===
# Fine-grained PAT with Contents: Read and write on the target repo.
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=fireflies-minutes

# === Trilium ===
TRILIUM_BASE_URL=https://trilium.geekendzone.com
TRILIUM_ETAPI_TOKEN=
# noteId of the parent note under which meeting notes are created.
TRILIUM_PARENT_NOTE_ID=

# === Email recipient ===
MEETING_RECIPIENT_EMAIL=jacedeno@geekendzone.com
